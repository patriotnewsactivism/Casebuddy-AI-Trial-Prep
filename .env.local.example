# ============================================
# CaseBuddy AI Trial Prep - Environment Setup
# ============================================
# 
# SECURITY ARCHITECTURE:
# All AI API keys (Gemini, OpenAI, ElevenLabs) are stored server-side
# in Supabase Edge Functions. The client only needs Supabase credentials.
#
# Copy this file to .env.local and fill in your values.
# ============================================

# -----------------
# Supabase (REQUIRED for production)
# -----------------
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

SUPABASE_URL=https://jpzkumgndqsdwimbvjku.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impwemt1bWduZHFzZHdpbWJ2amt1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE0NjA1NjYsImV4cCI6MjA4NzAzNjU2Nn0.IoN_MSuj8IjH8N_kKiffI5TxJlJUJXFm0vLkE9d3zCE

# -----------------
# Supabase Edge Functions Secrets (Set in Supabase Dashboard)
# -----------------
# DO NOT put these in .env.local - they are server-side only!
# Set these in Supabase Dashboard > Edge Functions > Settings:
#
# GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=
#ASSEMBLYAI_API_KEY=
# ELEVENLABS_API_KEY=
# OCR Provider Keys (set in Supabase Edge Functions):
# GOOGLE_DOCUMENT_AI_KEY=your-google-doc-ai-key
# GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1
# AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-key
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# MATHPIX_API_KEY=your-mathpix-key
# MATHPIX_APP_ID=your-mathpix-app-id
#
# Get API keys from:
# - Gemini: https://aistudio.google.com/apikey
# - OpenAI: https://platform.openai.com/api-keys
# - ElevenLabs: https://elevenlabs.io/app/settings/api-keys
# - Google Document AI: https://console.cloud.google.com/apis/credentials
# - AWS Textract: https://console.aws.amazon.com/iam/
# - Azure: https://portal.azure.com/
# - Mathpix: https://mathpix.com/

# -----------------
# Optional: Development Only (Client-Side Fallback)
# -----------------
# For local development without Supabase, you can temporarily
# set these. The app will fallback to direct API calls.
#
# WARNING: These will be visible in browser devtools!
# Only use for local testing, never deploy with these set.

# Primary AI (Gemini)
API_KEY=your-gemini-api-key-here
# or
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: OpenAI for fallback
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=215a79f6dc3c442982f4fb00793c535f

# -----------------
# Vite Environment Variables
# -----------------
# Variables prefixed with VITE_ are exposed to the client
# These are automatically available in your app

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Direct OCR keys for client-side (Tesseract only)
# Cloud OCR providers should use Supabase Edge Functions
VITE_GOOGLE_DOCUMENT_AI_KEY=
VITE_GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
VITE_AZURE_DOCUMENT_INTELLIGENCE_KEY=
VITE_AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_VISION_ENDPOINT=https://wtpvision.cognitiveservices.azure.com/
